FROM python:3.11-slim

# 1. Įdiegiame Node.js ir NPM į Python aplinką
RUN apt-get update && apt-get install -y curl \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /code

# 2. Nukopijuojame ir įdiegiame Python priklausomybes
COPY ./requirements.txt /code/requirements.txt
RUN pip install --no-cache-dir --upgrade -r /code/requirements.txt

# 3. Nukopijuojame ir įdiegiame Node.js priklausomybes
COPY package*.json /code/
RUN npm install

# 4. Nukopijuojame visą likusį kodą
COPY . /code

# 5. Paleidžiame abu procesus kartu fone naudodami "bash -c"
CMD ["sh", "-c", "npm run dev & uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"]